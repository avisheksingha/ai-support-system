# DATABASE
DB_USERNAME=postgres
DB_PASSWORD=your-database-password

# OpenAI
OPENAI_API_KEY=sk-your-real-openai-key

# OPTION 1: Google GenAI (Gemini API Key)
# Obtain an API key from the Google AI Studio (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your-google-api-key

# OPTION 2: Google GenAI (Vertex AI / Google Cloud)
# Install the gcloud CLI, appropriate for your OS.
# Authenticate by running the following command.
# Replace PROJECT_ID with your Google Cloud project ID and ACCOUNT with your Google Cloud username.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT
# Generate at least 32 random bytes and encode them as Base64.
# The same secret must be supplied to auth-service and api-gateway.
JWT_SECRET=replace-with-a-strong-base64-encoded-secret
